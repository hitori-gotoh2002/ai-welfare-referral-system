# Copy this file to .env for local development.
# Never commit real API keys or personal data.

# Public Data Portal / Bokjiro service key
DATA_GO_KR_SERVICE_KEY=

# Optional aliases accepted by the backend
BOKJIRO_SERVICE_KEY=
PUBLIC_DATA_SERVICE_KEY=

# Public Data API endpoints. Keep defaults unless the upstream endpoint changes.
BOKJIRO_NATIONAL_WELFARE_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfarelistV001
BOKJIRO_NATIONAL_WELFARE_DETAIL_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001/NationalWelfaredetailedV001
BOKJIRO_LOCAL_WELFARE_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfarelist
BOKJIRO_LOCAL_WELFARE_DETAIL_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations/LcgvWelfaredetailed

# Social service provider / private resource APIs
# If empty, the backend falls back to DATA_GO_KR_SERVICE_KEY where possible.
SOCIALSERVICE_SERVICE_KEY=
SOCIALSERVICE_PROVIDER_URL=https://api.socialservice.or.kr:444/api/service/provider/providerList
RESOURCE_INFO_URL=http://apis.data.go.kr/B554287/resrceInfoInqireService/getPrvateResrcInfoInqire

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Local server
HOST=0.0.0.0
PORT=5173

# MVP consultation storage.
# For production, replace this file storage with SQLite/PostgreSQL/Render Disk.
CASE_STORE_PATH=.data/cases.json
